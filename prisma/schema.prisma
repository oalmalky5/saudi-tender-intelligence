generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tender {
  id                   String  @id @default(cuid())
  referenceNumber      String  @unique
  tenderNumber         String?
  sourceTenderId       Int     @unique
  sourceTenderIdString String
  sourceUrl            String
  sourceSystem         String  @default("etimad")

  titleArabic        String
  titleEnglish       String?
  descriptionArabic  String? @db.Text
  descriptionEnglish String? @db.Text

  agencyNameArabic       String
  branchNameArabic       String?
  tenderTypeId           Int
  tenderTypeNameArabic   String
  tenderStatusId         Int
  tenderStatusNameArabic String?
  activityId             Int?
  activityNameArabic     String?

  classificationFieldArabic String?
  executionRegionArabic     String?
  executionCityArabic       String?
  executionDetailsArabic    String? @db.Text

  publishedAt        DateTime
  enquiriesDeadline  DateTime?
  submissionDeadline DateTime?
  offersOpeningAt    DateTime?
  expectedAwardAt    DateTime?
  workStartsAt       DateTime?

  contractDurationArabic         String?
  submissionMethodArabic         String?
  documentPrice                  Decimal? @db.Decimal(12, 2)
  financialFees                  Decimal? @db.Decimal(12, 2)
  invitationCost                 Decimal? @db.Decimal(12, 2)
  initialGuaranteeRequired       Boolean?
  finalGuaranteePercentage       Decimal? @db.Decimal(5, 2)
  insuranceRequired              Boolean?
  localContentRequirementsArabic String?  @db.Text

  hasInvitations    Boolean?
  isUgrp            Boolean  @default(false)
  externalSourceUrl String?

  sourcePayload          Json
  detailEnrichmentStatus String    @default("pending")
  detailEnrichmentError  String?   @db.Text
  detailsEnrichedAt      DateTime?
  firstSeenAt            DateTime  @default(now())
  lastSeenAt             DateTime  @default(now())
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  detailSnapshot TenderDetailSnapshot?
  attachments    TenderAttachment[]
  decision       TenderDecision?
  aiSummaries    TenderAiSummary[]
  translations   TenderTranslation[]

  @@index([agencyNameArabic])
  @@index([activityNameArabic])
  @@index([publishedAt])
  @@index([submissionDeadline])
}

enum TenderDecisionStatus {
  SAVED
  IGNORED
}

model TenderDecision {
  id        String                @id @default(cuid())
  tenderId  String                @unique
  status    TenderDecisionStatus?
  note      String?               @db.Text
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([status])
}

model TenderAttachment {
  id                  String   @id @default(cuid())
  tenderId            String
  sourceAttachmentKey String
  nameArabic          String
  sourceUrl           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@unique([tenderId, sourceAttachmentKey])
}

model TenderDetailSnapshot {
  id               String   @id @default(cuid())
  tenderId         String   @unique
  basicHtml        String   @db.Text
  datesHtml        String   @db.Text
  relationsHtml    String   @db.Text
  attachmentsHtml  String   @db.Text
  localContentHtml String   @db.Text
  awardingHtml     String   @db.Text
  parsedPayload    Json
  fetchedAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)
}

model CompanyProfile {
  id                        String   @id
  companyName               String
  summary                   String   @db.Text
  services                  String[] @default([])
  activities                String[] @default([])
  industries                String[] @default([])
  targetGovernmentEntities  String[] @default([])
  regions                   String[] @default([])
  preferredKeywords         String[] @default([])
  excludedKeywords          String[] @default([])
  preferredOpportunityTypes String[] @default([])
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  aiSummaries TenderAiSummary[]
}

model TenderAiSummary {
  id                            String    @id @default(cuid())
  tenderId                      String
  companyProfileId              String?
  content                       Json
  model                         String
  promptVersion                 String
  openaiResponseId              String?
  inputTokens                   Int?
  outputTokens                  Int?
  totalTokens                   Int?
  estimatedCostUsd              Decimal?  @db.Decimal(12, 6)
  sourceTenderUpdatedAt         DateTime
  sourceCompanyProfileUpdatedAt DateTime?
  generatedAt                   DateTime  @default(now())

  tender         Tender          @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  companyProfile CompanyProfile? @relation(fields: [companyProfileId], references: [id], onDelete: SetNull)

  @@index([tenderId, generatedAt])
  @@index([companyProfileId])
}

model TenderTranslation {
  id                 String   @id @default(cuid())
  tenderId           String
  titleEnglish       String
  descriptionEnglish String?  @db.Text
  sourceHash         String
  model              String
  promptVersion      String
  openaiResponseId   String?
  inputTokens        Int?
  outputTokens       Int?
  totalTokens        Int?
  estimatedCostUsd   Decimal? @db.Decimal(12, 6)
  generatedAt        DateTime @default(now())

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([tenderId, generatedAt])
  @@index([tenderId, sourceHash])
}
