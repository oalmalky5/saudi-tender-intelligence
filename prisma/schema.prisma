generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace?
}

model Workspace {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String
  isDemo    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyProfile  CompanyProfile?
  tenderDecisions TenderDecision[]
  booklets        TenderBooklet[]
  csvImports      CsvImportSession[]
  monitoringRuns  MonitoringRun[]
  aiSummaries     TenderAiSummary[]
  chatRuns        TenderChatRun[]
}

model RateLimitBucket {
  id          String   @id @default(cuid())
  key         String
  action      String
  windowStart DateTime
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([key, action, windowStart])
  @@index([windowStart])
}

model TenderMetadataTranslation {
  id          String   @id @default(cuid())
  category    String
  sourceText  String
  englishText String
  provider    String   @default("AZURE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([category, sourceText])
  @@index([category, englishText])
}

model GovernmentAgency {
  agencyCode    String   @id
  govAgencyCode Int
  nameArabic    String
  isOldSystem   Boolean  @default(false)
  firstSeenAt   DateTime @default(now())
  lastSeenAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([nameArabic])
  @@index([isOldSystem])
}

model Tender {
  id                   String  @id @default(cuid())
  referenceNumber      String  @unique
  tenderNumber         String?
  sourceTenderId       Int     @unique
  sourceTenderIdString String
  sourceUrl            String
  sourceSystem         String  @default("etimad")

  titleArabic        String
  titleEnglish       String?
  descriptionArabic  String? @db.Text
  descriptionEnglish String? @db.Text

  agencyNameArabic       String
  branchNameArabic       String?
  tenderTypeId           Int
  tenderTypeNameArabic   String
  tenderStatusId         Int
  tenderStatusNameArabic String?
  activityId             Int?
  activityNameArabic     String?

  classificationFieldArabic String?
  executionRegionArabic     String?
  executionCityArabic       String?
  executionDetailsArabic    String? @db.Text

  publishedAt        DateTime
  enquiriesDeadline  DateTime?
  submissionDeadline DateTime?
  offersOpeningAt    DateTime?
  expectedAwardAt    DateTime?
  workStartsAt       DateTime?

  contractDurationArabic         String?
  submissionMethodArabic         String?
  documentPrice                  Decimal? @db.Decimal(12, 2)
  financialFees                  Decimal? @db.Decimal(12, 2)
  invitationCost                 Decimal? @db.Decimal(12, 2)
  initialGuaranteeRequired       Boolean?
  finalGuaranteePercentage       Decimal? @db.Decimal(5, 2)
  insuranceRequired              Boolean?
  localContentRequirementsArabic String?  @db.Text

  hasInvitations    Boolean?
  isUgrp            Boolean  @default(false)
  externalSourceUrl String?

  sourcePayload          Json
  detailEnrichmentStatus String    @default("pending")
  detailEnrichmentError  String?   @db.Text
  detailsEnrichedAt      DateTime?
  firstSeenAt            DateTime  @default(now())
  lastSeenAt             DateTime  @default(now())
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  detailSnapshot      TenderDetailSnapshot?
  attachments         TenderAttachment[]
  decisions           TenderDecision[]
  aiSummaries         TenderAiSummary[]
  translations        TenderTranslation[]
  aiMatches           TenderAiMatch[]
  booklets            TenderBooklet[]
  chatCitations       TenderChatCitation[]
  notifications       Notification[]
  weeklyReportTenders WeeklyTenderReportTender[]

  @@index([agencyNameArabic])
  @@index([activityNameArabic])
  @@index([publishedAt])
  @@index([submissionDeadline])
}

enum TenderDecisionStatus {
  SAVED
  IGNORED
}

model TenderDecision {
  id          String                @id @default(cuid())
  workspaceId String
  tenderId    String
  status      TenderDecisionStatus?
  note        String?               @db.Text
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tender    Tender    @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, tenderId])
  @@index([workspaceId, status])
  @@index([status])
}

model TenderAttachment {
  id                  String   @id @default(cuid())
  tenderId            String
  sourceAttachmentKey String
  nameArabic          String
  sourceUrl           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@unique([tenderId, sourceAttachmentKey])
}

model TenderDetailSnapshot {
  id               String   @id @default(cuid())
  tenderId         String   @unique
  basicHtml        String   @db.Text
  datesHtml        String   @db.Text
  relationsHtml    String   @db.Text
  attachmentsHtml  String   @db.Text
  localContentHtml String   @db.Text
  awardingHtml     String   @db.Text
  parsedPayload    Json
  fetchedAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)
}

model CompanyProfile {
  id                             String   @id
  workspaceId                    String   @unique
  companyName                    String
  summary                        String   @db.Text
  services                       String[] @default([])
  activities                     String[] @default([])
  industries                     String[] @default([])
  targetGovernmentEntities       String[] @default([])
  regions                        String[] @default([])
  preferredKeywords              String[] @default([])
  excludedKeywords               String[] @default([])
  preferredOpportunityTypes      String[] @default([])
  notificationRelevanceThreshold Int      @default(40)
  deadlineReminderDays           Int      @default(7)
  digestFrequency                String   @default("DAILY")
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt

  aiSummaries     TenderAiSummary[]
  aiMatchRuns     TenderAiMatchRun[]
  bookletAnalyses TenderBookletAnalysis[]
  chatRuns        TenderChatRun[]
  notifications   Notification[]
  weeklyReports   WeeklyTenderReport[]
  workspace       Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model TenderAiSummary {
  id                            String    @id @default(cuid())
  workspaceId                   String
  tenderId                      String
  companyProfileId              String?
  content                       Json
  model                         String
  promptVersion                 String
  openaiResponseId              String?
  inputTokens                   Int?
  outputTokens                  Int?
  totalTokens                   Int?
  estimatedCostUsd              Decimal?  @db.Decimal(12, 6)
  sourceTenderUpdatedAt         DateTime
  sourceCompanyProfileUpdatedAt DateTime?
  generatedAt                   DateTime  @default(now())

  tender         Tender          @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  companyProfile CompanyProfile? @relation(fields: [companyProfileId], references: [id], onDelete: SetNull)
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, generatedAt])
  @@index([tenderId, generatedAt])
  @@index([companyProfileId])
}

model TenderTranslation {
  id                 String   @id @default(cuid())
  tenderId           String
  titleEnglish       String
  descriptionEnglish String?  @db.Text
  sourceHash         String
  provider           String   @default("OPENAI")
  translationType    String   @default("IMPROVED")
  model              String
  promptVersion      String
  characterCount     Int?
  openaiResponseId   String?
  inputTokens        Int?
  outputTokens       Int?
  totalTokens        Int?
  estimatedCostUsd   Decimal? @db.Decimal(12, 6)
  generatedAt        DateTime @default(now())

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([tenderId, generatedAt])
  @@index([tenderId, sourceHash])
  @@index([provider, sourceHash])
}

model TenderAiMatchRun {
  id                            String   @id @default(cuid())
  companyProfileId              String
  model                         String
  promptVersion                 String
  openaiResponseId              String?
  candidateCount                Int
  inputTokens                   Int?
  outputTokens                  Int?
  totalTokens                   Int?
  estimatedCostUsd              Decimal? @db.Decimal(12, 6)
  sourceCompanyProfileUpdatedAt DateTime
  generatedAt                   DateTime @default(now())

  companyProfile CompanyProfile  @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  matches        TenderAiMatch[]

  @@index([companyProfileId, generatedAt])
}

model TenderAiMatch {
  id                    String   @id @default(cuid())
  runId                 String
  tenderId              String
  rank                  Int
  relevanceScore        Int
  whyMatches            String[]
  whyMayNotMatch        String[]
  whatToCheckNext       String[]
  recommendedAction     String
  confidence            String
  deterministicScore    Int
  sourceTenderUpdatedAt DateTime

  run    TenderAiMatchRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  tender Tender           @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@unique([runId, tenderId])
  @@unique([runId, rank])
  @@index([tenderId])
}

model TenderBooklet {
  id                  String    @id @default(cuid())
  workspaceId         String
  tenderId            String
  originalName        String
  storedPath          String
  mimeType            String
  sizeBytes           Int
  sha256              String
  pageCount           Int
  extractedCharacters Int
  extractionStatus    String
  extractionMethod    String
  requiresOcr         Boolean   @default(false)
  extractionError     String?   @db.Text
  extractedAt         DateTime?
  createdAt           DateTime  @default(now())

  workspace Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tender    Tender                  @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  pages     TenderBookletPage[]
  analyses  TenderBookletAnalysis[]

  @@unique([workspaceId, tenderId, sha256])
  @@index([workspaceId, createdAt])
  @@index([tenderId, createdAt])
}

model TenderBookletPage {
  id             String @id @default(cuid())
  bookletId      String
  pageNumber     Int
  text           String @db.Text
  characterCount Int

  booklet TenderBooklet @relation(fields: [bookletId], references: [id], onDelete: Cascade)

  @@unique([bookletId, pageNumber])
}

model TenderBookletAnalysis {
  id                            String    @id @default(cuid())
  bookletId                     String
  companyProfileId              String?
  content                       Json
  model                         String
  promptVersion                 String
  schemaVersion                 String
  openaiResponseId              String?
  inputTokens                   Int?
  outputTokens                  Int?
  totalTokens                   Int?
  estimatedCostUsd              Decimal?  @db.Decimal(12, 6)
  sourceBookletSha256           String
  sourceCompanyProfileUpdatedAt DateTime?
  analyzedPageNumbers           Int[]
  generatedAt                   DateTime  @default(now())

  booklet        TenderBooklet   @relation(fields: [bookletId], references: [id], onDelete: Cascade)
  companyProfile CompanyProfile? @relation(fields: [companyProfileId], references: [id], onDelete: SetNull)

  @@index([bookletId, generatedAt])
  @@index([companyProfileId])
}

model TenderChatRun {
  id                            String    @id @default(cuid())
  workspaceId                   String
  question                      String    @db.Text
  content                       Json
  retrieval                     Json
  companyProfileId              String?
  model                         String
  promptVersion                 String
  openaiResponseId              String?
  retrievedTenderCount          Int
  inputTokens                   Int?
  outputTokens                  Int?
  totalTokens                   Int?
  estimatedCostUsd              Decimal?  @db.Decimal(12, 6)
  sourceCompanyProfileUpdatedAt DateTime?
  generatedAt                   DateTime  @default(now())
  clearedAt                     DateTime?

  companyProfile CompanyProfile?      @relation(fields: [companyProfileId], references: [id], onDelete: SetNull)
  workspace      Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  citations      TenderChatCitation[]

  @@index([workspaceId, generatedAt])
  @@index([workspaceId, clearedAt, generatedAt])
  @@index([generatedAt])
  @@index([companyProfileId])
}

model TenderChatCitation {
  id       String @id @default(cuid())
  runId    String
  tenderId String
  claim    String @db.Text

  run    TenderChatRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  tender Tender        @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([tenderId])
}

model CsvImportSession {
  id            String    @id @default(cuid())
  workspaceId   String
  originalName  String
  status        String
  headerMapping Json
  rows          Json
  totalRows     Int
  validRows     Int
  invalidRows   Int
  duplicateRows Int
  createdCount  Int?
  updatedCount  Int?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([createdAt])
}

model MonitoringRun {
  id                   String    @id @default(cuid())
  workspaceId          String
  status               String
  pagesFetched         Int       @default(0)
  recordsFetched       Int       @default(0)
  newTenderCount       Int       @default(0)
  changedTenderCount   Int       @default(0)
  unchangedTenderCount Int       @default(0)
  enrichedCount        Int       @default(0)
  enrichmentErrorCount Int       @default(0)
  notificationCount    Int       @default(0)
  errorMessage         String?   @db.Text
  startedAt            DateTime  @default(now())
  completedAt          DateTime?

  notifications Notification[]
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, startedAt])
  @@index([startedAt])
  @@index([status])
}

model Notification {
  id               String    @id @default(cuid())
  uniqueKey        String    @unique
  companyProfileId String
  tenderId         String?
  monitoringRunId  String?
  type             String
  title            String
  body             String    @db.Text
  relevanceScore   Int?
  reasons          String[]  @default([])
  readAt           DateTime?
  createdAt        DateTime  @default(now())

  companyProfile CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  tender         Tender?        @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  monitoringRun  MonitoringRun? @relation(fields: [monitoringRunId], references: [id], onDelete: SetNull)

  @@index([companyProfileId, createdAt])
  @@index([companyProfileId, readAt])
  @@index([tenderId])
}

model WeeklyTenderReport {
  id                            String   @id @default(cuid())
  companyProfileId              String
  dateFrom                      DateTime
  dateTo                        DateTime
  content                       Json
  markdown                      String   @db.Text
  model                         String
  promptVersion                 String
  openaiResponseId              String?
  candidateCount                Int
  inputTokens                   Int?
  outputTokens                  Int?
  totalTokens                   Int?
  estimatedCostUsd              Decimal? @db.Decimal(12, 6)
  sourceCompanyProfileUpdatedAt DateTime
  generatedAt                   DateTime @default(now())

  companyProfile CompanyProfile             @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  tenders        WeeklyTenderReportTender[]

  @@index([companyProfileId, generatedAt])
  @@index([dateFrom, dateTo])
}

model WeeklyTenderReportTender {
  id                    String   @id @default(cuid())
  reportId              String
  tenderId              String
  categories            String[]
  sourceTenderUpdatedAt DateTime

  report WeeklyTenderReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  tender Tender             @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@unique([reportId, tenderId])
  @@index([tenderId])
}
