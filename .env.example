# PostgreSQL connections. Prisma's local development database prints these
# values when `npm run db:dev` starts.
DATABASE_URL="postgres://postgres:postgres@localhost:PORT/template1?sslmode=disable"
SHADOW_DATABASE_URL="postgres://postgres:postgres@localhost:SHADOW_PORT/template1?sslmode=disable"

# Signed HTTP-only session cookies. Generate a production value with:
# openssl rand -base64 32
SESSION_SECRET=""

# Protects the scheduler endpoint. Generate a production value with:
# openssl rand -base64 32
CRON_SECRET=""
MONITOR_WORKSPACE_ID="primary-workspace"

# Optional demo-account overrides. Production requires DEMO_USER_PASSWORD when
# running `npm run auth:seed-demo`.
DEMO_USER_EMAIL="demo@etimad.local"
DEMO_USER_PASSWORD=""

# Server-side secret. Never rename this with a NEXT_PUBLIC_ prefix.
OPENAI_API_KEY=""

# Optional per-feature model overrides.
OPENAI_SUMMARY_MODEL="gpt-5-mini"
OPENAI_TRANSLATION_MODEL="gpt-5-mini"
OPENAI_MATCHING_MODEL="gpt-5-mini"
OPENAI_BOOKLET_MODEL="gpt-5-mini"
OPENAI_CHAT_MODEL="gpt-5-mini"
OPENAI_WEEKLY_REPORT_MODEL="gpt-5-mini"

# Automatic Arabic-to-English tender translation. Global single-service
# Translator resources do not require a region value.
AZURE_TRANSLATOR_KEY=""
AZURE_TRANSLATOR_ENDPOINT="https://api.cognitive.microsofttranslator.com"
AZURE_TRANSLATOR_REGION=""
